# UserDesk – Konfigurationsvorlage
# Kopieren als .env und ausfüllen. Diese Datei darf auf Git, .env niemals!

# LDAP / Active Directory
AD_SERVER=192.168.1.10
AD_PORT=636
AD_SSL=true
AD_USER=CN=svc_ldap,OU=ServiceAccounts,DC=example,DC=com
AD_PASSWORD=
BASE_DN=DC=example,DC=com

# Nur User in dieser OU dürfen sich anmelden (OU-Name, nicht DN).
# Leer lassen = alle AD-User dürfen sich anmelden.
ADMIN_OU=

# Ziel-OU (vollständiger DN) für den "Ins Lager" Button bei Geräten.
# Leer lassen = Schnell-Aktion wird nicht angezeigt.
LAGER_OU=

# Kommagetrennte CN-Präfixe die als "Computer-Objekte" gelten (Kleinschreibung).
# Leer lassen = Schnell-Aktion wird nie angezeigt.
COMPUTER_PREFIX=nb,mb

# SMTP – Wöchentlicher Report (optional)
# Jeden Montag 07:00 Uhr wird ein Bericht gesendet mit gesperrten Usern & ablaufenden Passwörtern.
# Leer lassen = kein Mail-Versand.
SMTP_HOST=
SMTP_PORT=587
SMTP_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=
